<!-- ─── CTA ───────────────────────────────────────────────────────── -->
<section class="cta-banner">
  <div class="container">
    <h2>Found Your Perfect Match?</h2>
    <p>Reach out today to ask questions, schedule a video call, or reserve your puppy with a $200 deposit.</p>
    <div class="cta-actions">
      <a href="/contact" class="btn btn-primary btn-lg">Reserve a Puppy →</a>
      <a href="https://wa.me/15302080445" target="_blank" rel="noopener" class="btn btn-ghost btn-lg">Chat on WhatsApp</a>
    </div>
  </div>
</section>

<%- include('partials/footer') %>

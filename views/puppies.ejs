<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- ─── Page Header ─────────────────────────────────────────────── -->
<section class="page-header" style="background-image: linear-gradient(135deg, rgba(22,14,8,.92) 0%, rgba(33,23,16,.80) 55%, rgba(74,48,32,.85) 100%), url('/image/females%20(1).jpg'); background-size: cover; background-position: center top;">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span>Available Puppies</span>
    </div>
    <p class="section-label">Both Breeds · Ready to Come Home</p>
    <h1>Available Cocker Spaniel<br>Puppies</h1>
    <p class="lead">Home-raised American and English Cocker Spaniels — all vaccinated, health-guaranteed, and ready for forever families.</p>
    <div style="display:flex; gap:12px; flex-wrap:wrap; margin-top:28px;">
      <a href="#american" class="btn btn-primary btn-lg">🇺🇸 American Cockers</a>
      <a href="#english"  class="btn btn-ghost   btn-lg">🇬🇧 English Cockers</a>
    </div>
  </div>
</section>

<!-- ─── Breed Quick Nav ──────────────────────────────────────────── -->
<%
  var amTotal  = americanFemales.length + americanMales.length;
  var engTotal = englishFemales.length  + englishMales.length;
%>
<div class="breed-hub-bar">
  <div class="container">
    <a href="#american" class="breed-hub-pill">
      <span class="breed-hub-flag">🇺🇸</span>
      <span class="breed-hub-info">
        <strong>American Cocker Spaniel</strong>
        <span><%= amTotal %> puppy<%= amTotal !== 1 ? 'ies' : '' %> · AKC · From $1,000</span>
      </span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
    <div class="breed-hub-divider"></div>
    <a href="#english" class="breed-hub-pill breed-hub-pill-eng">
      <span class="breed-hub-flag">🇬🇧</span>
      <span class="breed-hub-info">
        <strong>English Cocker Spaniel</strong>
        <span><%= engTotal %> puppy<%= engTotal !== 1 ? 'ies' : '' %> · KC · From $1,400</span>
      </span>
      <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" width="14" height="14"><polyline points="6 9 12 15 18 9"/></svg>
    </a>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     AMERICAN COCKER SPANIEL
     ═══════════════════════════════════════════════════════════════ -->
<section class="section" id="american">
  <div class="container">

    <!-- Breed header -->
    <div class="breed-listing-head">
      <div class="breed-listing-title-wrap">
        <span class="breed-listing-flag">🇺🇸</span>
        <div>
          <h2 class="breed-listing-title">American Cocker Spaniel</h2>
          <p class="breed-listing-sub">AKC Registered &bull; 2-Year Health Guarantee &bull; Vaccinated &bull; Microchipped</p>
        </div>
      </div>
      <a href="/available-puppies/english-cocker-spaniel" class="btn btn-secondary btn-sm" style="white-space:nowrap;">View English Page →</a>
    </div>

    <!-- Credentials bar -->
    <div class="breed-cred-bar">
      <span class="breed-cred-item">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.75" width="14" height="14"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        AKC Registered
      </span>
      <span class="breed-cred-item">🏥 Health Tested Parents</span>
      <span class="breed-cred-item">💉 Fully Vaccinated</span>
      <span class="breed-cred-item">📋 2-Year Guarantee</span>
    </div>

    <!-- Jump links -->
    <div style="display:flex; gap:9px; margin-bottom:32px;">
      <a href="#am-females" class="btn btn-secondary btn-sm">🎀 Females (<%= americanFemales.length %>)</a>
      <a href="#am-males"   class="btn btn-secondary btn-sm">🐾 Males (<%= americanMales.length %>)</a>
    </div>

    <!-- Females -->
    <div id="am-females">
      <div class="gender-divider"><h3>🎀 Female Puppies</h3></div>
      <% if (americanFemales.length === 0) { %>
        <p style="color:var(--text-mid); font-size:.95rem;">No female puppies currently available. <a href="/contact">Contact us</a> to join the waitlist.</p>
      <% } else { %>
      <div class="puppies-grid">
        <% americanFemales.forEach((puppy, i) => { %>
        <div class="puppy-card">
          <div class="puppy-card-img-wrap">
            <img src="<%= puppy.image %>" alt="<%= puppy.name %> – <%= puppy.color %> American Cocker Spaniel" loading="lazy">
            <span class="puppy-card-status"><span class="badge<%= (puppy.status||'Available')==='Reserved' ? ' badge-reserved' : (puppy.status||'Available')==='Sold' ? ' badge-sold' : '' %>"><%= puppy.status || 'Available' %></span></span>
            <span class="puppy-card-gender">♀ Female</span>
            <span class="breed-tag-card">🇺🇸 American</span>
          </div>
          <div class="puppy-card-body">
            <div class="puppy-card-name"><%= puppy.name %></div>
            <div class="puppy-card-color"><%= puppy.color %></div>
            <% if (i === 0) { %><span class="urgency-badge">&#9679; High Interest</span><% } %>
            <% if (i === 1) { %><span class="urgency-badge">&#9679; Inquiry Received</span><% } %>
            <div class="puppy-card-meta" style="margin-top:10px;">
              <span class="puppy-meta-tag">🐾 <%= puppy.age %></span>
              <span class="puppy-meta-tag">AKC Registered</span>
            </div>
            <div class="puppy-card-footer">
              <div class="puppy-price">$<%= puppy.price.toLocaleString() %><span class="puppy-price-note">+ delivery</span></div>
              <a href="/puppies/<%= puppy.slug %>" class="btn btn-primary btn-sm">View Details</a>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

    <!-- Males -->
    <div id="am-males" style="margin-top:60px;">
      <div class="gender-divider"><h3>🐾 Male Puppies</h3></div>
      <% if (americanMales.length === 0) { %>
        <p style="color:var(--text-mid); font-size:.95rem;">No male puppies currently available. <a href="/contact">Contact us</a> to join the waitlist.</p>
      <% } else { %>
      <div class="puppies-grid">
        <% americanMales.forEach((puppy, i) => { %>
        <div class="puppy-card">
          <div class="puppy-card-img-wrap">
            <img src="<%= puppy.image %>" alt="<%= puppy.name %> – <%= puppy.color %> American Cocker Spaniel" loading="lazy">
            <span class="puppy-card-status"><span class="badge<%= (puppy.status||'Available')==='Reserved' ? ' badge-reserved' : (puppy.status||'Available')==='Sold' ? ' badge-sold' : '' %>"><%= puppy.status || 'Available' %></span></span>
            <span class="puppy-card-gender">♂ Male</span>
            <span class="breed-tag-card">🇺🇸 American</span>
          </div>
          <div class="puppy-card-body">
            <div class="puppy-card-name"><%= puppy.name %></div>
            <div class="puppy-card-color"><%= puppy.color %></div>
            <% if (i === 0) { %><span class="urgency-badge">&#9679; High Interest</span><% } %>
            <div class="puppy-card-meta" style="margin-top:10px;">
              <span class="puppy-meta-tag">🐾 <%= puppy.age %></span>
              <span class="puppy-meta-tag">AKC Registered</span>
            </div>
            <div class="puppy-card-footer">
              <div class="puppy-price">$<%= puppy.price.toLocaleString() %><span class="puppy-price-note">+ delivery</span></div>
              <a href="/puppies/<%= puppy.slug %>" class="btn btn-primary btn-sm">View Details</a>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

  </div>
</section>

<!-- ─── Divider ───────────────────────────────────────────────────── -->
<div class="breed-hub-divider-full">
  <div class="container">
    <div class="breed-hub-divider-line">
      <span class="breed-hub-divider-label">🐾 Also Available</span>
    </div>
  </div>
</div>

<!-- ═══════════════════════════════════════════════════════════════
     ENGLISH COCKER SPANIEL
     ═══════════════════════════════════════════════════════════════ -->

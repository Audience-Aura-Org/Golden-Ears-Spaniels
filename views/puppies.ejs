<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- ─── Page Header ─────────────────────────────────────────────── -->
<section class="page-header" style="background-image: linear-gradient(135deg, rgba(33,23,16,.88) 0%, rgba(33,23,16,.76) 55%, rgba(74,48,32,.82) 100%), url('/image/females%20(1).jpg'); background-size: cover; background-position: center top;">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span>Available Puppies</span>
    </div>
    <p class="section-label">Ready to Come Home</p>
    <h1>Available Cocker Spaniel<br>Puppies</h1>
    <p class="lead">All puppies are 11 weeks old, AKC registered, fully vaccinated, and ready for their forever families. Every puppy includes a written 2-year health guarantee.</p>
    <div style="display:flex; gap:14px; flex-wrap:wrap; margin-top:28px;">
      <a href="https://wa.me/15302080445" target="_blank" rel="noopener" class="btn btn-primary btn-lg" style="display:inline-flex; align-items:center; gap:9px;">
        <svg viewBox="0 0 24 24" xmlns="http://www.w3.org/2000/svg" style="width:18px;height:18px;fill:#fff;flex-shrink:0;"><path d="M17.472 14.382c-.297-.149-1.758-.867-2.03-.967-.273-.099-.471-.148-.67.15-.197.297-.767.966-.94 1.164-.173.199-.347.223-.644.075-.297-.15-1.255-.463-2.39-1.475-.883-.788-1.48-1.761-1.653-2.059-.173-.297-.018-.458.13-.606.134-.133.298-.347.446-.52.149-.174.198-.298.298-.497.099-.198.05-.371-.025-.52-.075-.149-.669-1.612-.916-2.207-.242-.579-.487-.5-.669-.51-.173-.008-.371-.01-.57-.01-.198 0-.52.074-.792.372-.272.297-1.04 1.016-1.04 2.479 0 1.462 1.065 2.875 1.213 3.074.149.198 2.096 3.2 5.077 4.487.709.306 1.262.489 1.694.625.712.227 1.36.195 1.871.118.571-.085 1.758-.719 2.006-1.413.248-.694.248-1.289.173-1.413-.074-.124-.272-.198-.57-.347m-5.421 7.403h-.004a9.87 9.87 0 01-5.031-1.378l-.361-.214-3.741.982.998-3.648-.235-.374a9.86 9.86 0 01-1.51-5.26c.001-5.45 4.436-9.884 9.888-9.884 2.64 0 5.122 1.03 6.988 2.898a9.825 9.825 0 012.893 6.994c-.003 5.45-4.437 9.884-9.885 9.884m8.413-18.297A11.815 11.815 0 0012.05 0C5.495 0 .16 5.335.157 11.892c0 2.096.547 4.142 1.588 5.945L.057 24l6.305-1.654a11.882 11.882 0 005.683 1.448h.005c6.554 0 11.89-5.335 11.893-11.893a11.821 11.821 0 00-3.48-8.413z"/></svg>
        Chat on WhatsApp
      </a>
      <a href="/contact" class="btn btn-ghost btn-lg">Ask a Question</a>
    </div>
  </div>
</section>

<!-- ─── Breed Switch Bar ─────────────────────────────────────────── -->
<div class="breed-switch-bar">
  <div class="container">
    <span class="breed-switch-label">Browse by breed:</span>
    <a href="/available-puppies" class="breed-switch-btn breed-switch-active">
      🇺🇸 American Cocker Spaniel
    </a>
    <a href="/available-puppies/english-cocker-spaniel" class="breed-switch-btn">
      🇬🇧 English Cocker Spaniel
    </a>
  </div>
</div>

<!-- ─── Puppies Listing ──────────────────────────────────────────── -->
<section class="section">
  <div class="container">

    <!-- Top bar -->
    <div style="display:flex; align-items:center; justify-content:space-between; flex-wrap:wrap; gap:12px; margin-bottom:32px; padding-bottom:20px; border-bottom:1px solid var(--cream-border);">
      <div style="display:flex; align-items:center; gap:8px; flex-wrap:wrap;">
        <svg viewBox="0 0 24 24" fill="none" stroke="var(--brown)" stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" style="width:17px;height:17px;flex-shrink:0;"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        <span style="font-size:.83rem; color:var(--text-mid);">AKC registered &bull; 2-yr health guarantee &bull; Vaccinated &bull; Microchipped</span>
      </div>
      <div style="display:flex; gap:9px;">
        <a href="#females" class="btn btn-secondary btn-sm">🎀 Females (<%= females.length %>)</a>
        <a href="#males"   class="btn btn-secondary btn-sm">🐾 Males (<%= males.length %>)</a>
      </div>
    </div>

    <!-- Females -->
    <div id="females">
      <div class="gender-divider">
        <h3>🎀 Female Puppies</h3>
      </div>
      <% if (females.length === 0) { %>
        <p style="color:var(--text-mid); font-size:.95rem;">No female puppies currently available. <a href="/contact">Contact us</a> to join the waitlist for the next litter.</p>
      <% } else { %>
      <div class="puppies-grid">
        <% females.forEach((puppy, i) => { %>
        <div class="puppy-card">
          <div class="puppy-card-img-wrap">
            <img src="<%= puppy.image %>" alt="<%= puppy.name %> – <%= puppy.color %> Cocker Spaniel Puppy" loading="lazy">
            <span class="puppy-card-status"><span class="badge<%= (puppy.status||'Available')==='Reserved' ? ' badge-reserved' : (puppy.status||'Available')==='Sold' ? ' badge-sold' : '' %>"><%= puppy.status || 'Available' %></span></span>
            <span class="puppy-card-gender">♀ Female</span>
          </div>
          <div class="puppy-card-body">
            <div class="puppy-card-name"><%= puppy.name %></div>
            <div class="puppy-card-color"><%= puppy.color %></div>
            <% if (i === 0) { %><span class="urgency-badge">&#9679; High Interest</span><% } %>
            <% if (i === 1) { %><span class="urgency-badge">&#9679; Inquiry Received</span><% } %>
            <div class="puppy-card-meta" style="margin-top:10px;">
              <span class="puppy-meta-tag">🐾 <%= puppy.age %></span>
              <span class="puppy-meta-tag">AKC Registered</span>
            </div>
            <div class="puppy-card-footer">
              <div class="puppy-price">
                $<%= puppy.price.toLocaleString() %>
                <span class="puppy-price-note">+ delivery</span>
              </div>
              <a href="/puppies/<%= puppy.slug %>" class="btn btn-primary btn-sm">View Details</a>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

    <!-- Males -->
    <div id="males" style="margin-top: 60px;">
      <div class="gender-divider">
        <h3>🐾 Male Puppies</h3>
      </div>
      <% if (males.length === 0) { %>
        <p style="color:var(--text-mid); font-size:.95rem;">No male puppies currently available. <a href="/contact">Contact us</a> to join the waitlist.</p>
      <% } else { %>
      <div class="puppies-grid">
        <% males.forEach((puppy, i) => { %>
        <div class="puppy-card">
          <div class="puppy-card-img-wrap">
            <img src="<%= puppy.image %>" alt="<%= puppy.name %> – <%= puppy.color %> Cocker Spaniel Puppy" loading="lazy">
            <span class="puppy-card-status"><span class="badge<%= (puppy.status||'Available')==='Reserved' ? ' badge-reserved' : (puppy.status||'Available')==='Sold' ? ' badge-sold' : '' %>"><%= puppy.status || 'Available' %></span></span>
            <span class="puppy-card-gender">♂ Male</span>
          </div>
          <div class="puppy-card-body">
            <div class="puppy-card-name"><%= puppy.name %></div>
            <div class="puppy-card-color"><%= puppy.color %></div>
            <% if (i === 0) { %><span class="urgency-badge">&#9679; High Interest</span><% } %>
            <div class="puppy-card-meta" style="margin-top:10px;">
              <span class="puppy-meta-tag">🐾 <%= puppy.age %></span>
              <span class="puppy-meta-tag">AKC Registered</span>
            </div>
            <div class="puppy-card-footer">
              <div class="puppy-price">
                $<%= puppy.price.toLocaleString() %>
                <span class="puppy-price-note">+ delivery</span>
              </div>
              <a href="/puppies/<%= puppy.slug %>" class="btn btn-primary btn-sm">View Details</a>
            </div>
          </div>
        </div>
        <% }); %>
      </div>
      <% } %>
    </div>

  </div>
</section>

<!-- ─── CTA ───────────────────────────────────────────────────────── -->
<section class="cta-banner">
  <div class="container">
    <h2>Found Your Perfect Match?</h2>
    <p>Reach out today to ask questions, schedule a video call, or reserve your puppy with a deposit.</p>
    <a href="/contact" class="btn btn-primary btn-lg">Get in Touch →</a>
  </div>
</section>

<%- include('partials/footer') %>

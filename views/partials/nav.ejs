<!-- ─── Top Bar ────────────────────────────────────────────────── -->
<div class="topbar">
  <div class="container topbar-inner">
    <div class="topbar-items">
      <a href="tel:<%= settings.contact.phone_tel %>" class="topbar-item">
        <svg class="topbar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M22 16.92v3a2 2 0 01-2.18 2 19.79 19.79 0 01-8.63-3.07A19.5 19.5 0 013.07 10.8 19.79 19.79 0 01.1 2.18a2 2 0 012-2.18h3a2 2 0 012 1.72 12.84 12.84 0 00.7 2.81 2 2 0 01-.45 2.11L6.91 7.91a16 16 0 006.72 6.72l1.39-1.39a2 2 0 012.11-.45 12.84 12.84 0 002.81.7A2 2 0 0122 16.92z"/></svg>
        <%= settings.contact.phone_display %>
      </a>
      <span class="topbar-divider">|</span>
      <a href="mailto:<%= settings.contact.email %>" class="topbar-item">
        <svg class="topbar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M4 4h16c1.1 0 2 .9 2 2v12c0 1.1-.9 2-2 2H4c-1.1 0-2-.9-2-2V6c0-1.1.9-2 2-2z"/><polyline points="22,6 12,13 2,6"/></svg>
        <%= settings.contact.email %>
      </a>
    </div>
    <div class="topbar-right">
      <span class="topbar-item topbar-hours">
        <svg class="topbar-icon" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><circle cx="12" cy="12" r="10"/><polyline points="12 6 12 12 16 14"/></svg>
        <%= settings.contact.hours %>
      </span>
    </div>
  </div>
</div>


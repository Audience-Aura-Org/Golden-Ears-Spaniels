<%- include('partials/head') %>
<%- include('partials/nav') %>

<!-- ─── Hero ──────────────────────────────────────────────────────── -->
<section class="hero">
  <div class="container hero-inner">
    <div class="hero-content">
      <div class="hero-eyebrow">
        <span>AKC Registered Since 2019</span>
      </div>
      <h1>Beautiful <em>Cocker Spaniel</em> Puppies, Raised with Love</h1>
      <p class="lead">Home-raised, health-tested American Cocker Spaniel puppies with a 2-year guarantee. Delivered safely to your door across the USA & Canada.</p>
      <div class="hero-actions">
        <a href="/available-puppies" class="btn btn-primary btn-lg">View Available Puppies</a>
        <a href="/about" class="btn btn-secondary btn-lg">Meet Our Breeders</a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <strong>9</strong>
          <span>Puppies Available</span>
        </div>
        <div class="hero-stat">
          <strong>5★</strong>
          <span>Verified Reviews</span>
        </div>
        <div class="hero-stat">
          <strong>2yr</strong>
          <span>Health Guarantee</span>
        </div>
      </div>
    </div>

    <div class="hero-visual">
      <img
        class="hero-img-main"
        src="https://images.unsplash.com/photo-1759745063508-cb193519f3ae?w=900&auto=format&fit=crop&q=80"
        alt="Beautiful Cocker Spaniel puppy"
        loading="eager"
      >
      <div class="hero-badge-floating">
        <div class="hero-badge-icon">✅</div>
        <div class="hero-badge-text">
          <strong>All Puppies Health-Tested</strong>
          <span>Genetic screening &amp; AKC registered</span>
        </div>
      </div>
    </div>
  </div>
</section>

<!-- ─── Why Choose Us ─────────────────────────────────────────────── -->
<section class="section" style="background: var(--white);">
  <div class="container">
    <p class="section-label text-center">Why Golden Ears</p>
    <h2 class="text-center">The Cocker Spaniel Difference</h2>
    <p class="lead text-center" style="max-width:600px; margin: 16px auto 0;">
      We pour our hearts into raising healthy, happy puppies that will bring joy to your family for a lifetime.
    </p>
    <div class="why-grid">
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
        </div>
        <h4>Home-Raised</h4>
        <p>Our puppies grow up in our family home — not a commercial kennel. They're socialized with children, other pets, and everyday sounds from day one.</p>
      </div>
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M9 12.75L11.25 15 15 9.75m-3-7.036A11.959 11.959 0 013.598 6 11.99 11.99 0 003 9.749c0 5.592 3.824 10.29 9 11.623 5.176-1.332 9-6.03 9-11.622 0-1.31-.21-2.571-.598-3.751h-.152c-3.196 0-6.1-1.248-8.25-3.285z"/></svg>
        </div>
        <h4>2-Year Health Guarantee</h4>
        <p>Every puppy comes with comprehensive genetic health screening, eye and hip clearances, full vet records, and a written 2-year health guarantee.</p>
      </div>
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>
        </div>
        <h4>AKC Registered</h4>
        <p>All parent dogs are AKC registered with champion bloodlines. Your puppy comes with AKC registration paperwork ready to complete.</p>
      </div>
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M12 21a9.004 9.004 0 008.716-6.747M12 21a9.004 9.004 0 01-8.716-6.747M12 21c2.485 0 4.5-4.03 4.5-9S14.485 3 12 3m0 18c-2.485 0-4.5-4.03-4.5-9S9.515 3 12 3m0 0a8.997 8.997 0 017.843 4.582M12 3a8.997 8.997 0 00-7.843 4.582m15.686 0A11.953 11.953 0 0112 10.5c-2.998 0-5.74-1.1-7.843-2.918m15.686 0A8.959 8.959 0 0121 12c0 .778-.099 1.533-.284 2.253m0 0A17.919 17.919 0 0112 16.5c-3.162 0-6.133-.815-8.716-2.247m0 0A9.015 9.015 0 013 12c0-1.605.42-3.113 1.157-4.418"/></svg>
        </div>
        <h4>Nationwide Delivery</h4>
        <p>We deliver to all 50 US states and Canada. Choose from road transport, air cargo, door-to-door, or our premium flight nanny service.</p>
      </div>
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M12 9v6m3-3H9m12 0a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
        </div>
        <h4>Up-to-Date Vaccinations</h4>
        <p>Puppies leave us current on all age-appropriate vaccines, dewormed, microchipped, and vet-examined — ready for their new home.</p>
      </div>
      <div class="why-card">
        <div class="why-card-icon">
          <svg viewBox="0 0 24 24"><path d="M21 8.25c0-2.485-2.099-4.5-4.688-4.5-1.935 0-3.597 1.126-4.312 2.733-.715-1.607-2.377-2.733-4.313-2.733C5.1 3.75 3 5.765 3 8.25c0 7.22 9 12 9 12s9-4.78 9-12z"/></svg>
        </div>
        <h4>Lifetime Breeder Support</h4>
        <p>We stay in touch after adoption. Have a question about nutrition, training, or health? Our team is always just a message away.</p>
      </div>
    </div>
  </div>
</section>

<!-- ─── Featured Puppies ──────────────────────────────────────────── -->
<section class="section" style="background: var(--cream);">
  <div class="container">
    <p class="section-label text-center">Ready to Go Home</p>
    <h2 class="text-center">Meet Our Available Puppies</h2>
    <p class="lead text-center" style="max-width:540px; margin: 16px auto 40px;">
      All puppies are 11 weeks old, fully vaccinated, and ready for their forever families.
    </p>

    <div class="puppies-grid puppies-grid-4">
      <% [...featuredFemales, ...featuredMales].forEach(puppy => { %>
      <div class="puppy-card">
        <div class="puppy-card-img-wrap">
          <img src="<%= puppy.image %>" alt="<%= puppy.name %> – <%= puppy.color %> Cocker Spaniel" loading="lazy">
          <span class="puppy-card-status"><span class="badge">Available</span></span>
          <span class="puppy-card-gender"><%= puppy.gender === 'Female' ? '♀ Female' : '♂ Male' %></span>
        </div>
        <div class="puppy-card-body">
          <div class="puppy-card-name"><%= puppy.name %></div>
          <div class="puppy-card-color"><%= puppy.color %></div>
          <p class="puppy-card-desc"><%= puppy.description.substring(0, 120) %>…</p>
          <div class="puppy-card-meta">
            <span class="puppy-meta-tag">🐾 <%= puppy.age %></span>
            <span class="puppy-meta-tag">AKC Registered</span>
          </div>
          <div class="puppy-card-footer">
            <div class="puppy-price">
              $<%= puppy.price.toLocaleString() %>
              <span class="puppy-price-note">+ delivery</span>
            </div>
            <a href="/puppies/<%= puppy.slug %>" class="btn btn-primary btn-sm">View Details</a>
          </div>
        </div>
      </div>
      <% }); %>
    </div>

    <div class="text-center" style="margin-top: 40px;">
      <a href="/available-puppies" class="btn btn-dark btn-lg">See All 9 Available Puppies →</a>
    </div>
  </div>
</section>

<!-- ─── How It Works ─────────────────────────────────────────────── -->
<section class="section" style="background:var(--white);">
  <div class="container">
    <p class="section-label text-center">Simple Process</p>
    <h2 class="text-center">How Adoption Works</h2>
    <p class="lead text-center" style="max-width:520px; margin:14px auto 0;">From first contact to your puppy arriving home — here's exactly what to expect.</p>
    <div class="steps-grid">
      <div class="step-card">
        <div class="step-num">1</div>
        <h4>Browse &amp; Choose</h4>
        <p>View all available puppies, read their profiles, and pick the one that steals your heart.</p>
      </div>
      <div class="step-card">
        <div class="step-num">2</div>
        <h4>Reserve with Deposit</h4>
        <p>A $200 refundable deposit holds your chosen puppy. We accept Zelle, CashApp, and bank transfer.</p>
      </div>
      <div class="step-card">
        <div class="step-num">3</div>
        <h4>Prepare Your Home</h4>
        <p>We send you a puppy prep checklist and stay available to answer every question before delivery.</p>
      </div>
      <div class="step-card">
        <div class="step-num">4</div>
        <h4>Puppy Arrives</h4>
        <p>Your puppy is delivered to your door, fully vaccinated, microchipped, and with all health documents.</p>
      </div>
    </div>
    <div class="text-center" style="margin-top:36px;">
      <a href="/faq" class="btn btn-secondary">Read Our FAQ</a>
    </div>
  </div>
</section>

<!-- ─── Delivery Options ──────────────────────────────────────────── -->
<section class="section delivery-section">
  <div class="container">
    <p class="section-label text-center">Safe & Reliable</p>
    <h2 class="text-center">Delivery Across the USA & Canada</h2>
    <p class="lead text-center" style="max-width:560px; margin:16px auto 0;">
      We offer flexible delivery options so your new companion reaches you safely, wherever you are.
    </p>
    <div class="delivery-grid">
      <% deliveryOptions.forEach(opt => { %>
      <div class="delivery-card">
        <div class="delivery-card-icon"><%- opt.icon %></div>
        <div class="delivery-card-price"><%= opt.price %></div>
        <h4><%= opt.title %></h4>
        <p><%= opt.description %></p>
      </div>
      <% }); %>
    </div>
    <div class="text-center" style="margin-top: 40px;">
      <a href="/contact" class="btn btn-primary">Ask About Delivery to Your City</a>
    </div>
  </div>
</section>

<!-- ─── Breed Traits ──────────────────────────────────────────────── -->
<section class="section" style="background: var(--white);">
  <div class="container">
    <div class="split-2">
      <div>
        <p class="section-label">The American Cocker Spaniel</p>
        <h2>A Breed Born to Love</h2>
        <p class="lead" style="margin: 20px 0 28px;">
          The American Cocker Spaniel is one of the most beloved dog breeds in the world — and for good reason. Their silky coats, expressive eyes, and joyful temperament make them perfect companions for families of all sizes.
        </p>
        <ul style="display:flex; flex-direction:column; gap:12px;">
          <% ['Beautiful, expressive eyes that melt your heart','Soft, silky coats in a rainbow of colors','Gentle, affectionate, patient personalities','High intelligence and eager-to-please nature','Excellent compatibility with children and other pets','Adaptable to apartments and large homes alike'].forEach(trait => { %>
          <li style="display:flex; align-items:center; gap:12px; font-size:.92rem; color:var(--text-mid);">
            <span style="color:var(--gold); font-size:1.1rem;">✦</span>
            <%= trait %>
          </li>
          <% }); %>
        </ul>
        <div style="margin-top:32px;">
          <a href="/available-puppies" class="btn btn-primary">Browse Available Puppies</a>
        </div>
      </div>
      <div>
        <img
          src="https://images.unsplash.com/photo-1591856419156-3979c9edd30f?w=800&auto=format&fit=crop&q=80"
          alt="Cocker Spaniel showing breed traits"
          style="width:100%; border-radius:var(--radius-xl); box-shadow:var(--shadow-lg); aspect-ratio:4/3; object-fit:cover;"
          loading="lazy"
        >
      </div>
    </div>
  </div>
</section>

<!-- ─── Testimonials ──────────────────────────────────────────────── -->
<section class="section testimonials-section">
  <div class="container">
    <p class="section-label text-center">What Families Say</p>
    <h2 class="text-center">Real Stories, Real Love</h2>
    <p class="lead text-center" style="max-width:540px; margin:16px auto 0;">
      Verified 5-star experiences from families who welcomed a Golden Ears puppy into their home.
    </p>
    <div class="testimonials-grid">
      <% testimonials.slice(0, 3).forEach(t => { %>
      <div class="testimonial-card">
        <div class="stars">
          <% for(let i = 0; i < t.rating; i++) { %><span>★</span><% } %>
        </div>
        <p class="testimonial-text">"<%= t.text %>"</p>
        <div class="testimonial-author">
          <div class="testimonial-avatar">🙋</div>
          <div>
            <div class="testimonial-name"><%= t.name %></div>
            <div class="testimonial-loc">📍 <%= t.location %></div>
          </div>
        </div>
      </div>
      <% }); %>
    </div>
  </div>
</section>

<!-- ─── CTA ───────────────────────────────────────────────────────── -->
<section class="cta-banner">
  <div class="container">
    <h2>Ready to Find Your Perfect Companion?</h2>
    <p>All puppies are available now and ready to go home. Reach out and we'll guide you every step of the way.</p>
    <a href="/contact" class="btn btn-primary btn-lg">Reserve a Puppy Today</a>
  </div>
</section>

<%- include('partials/footer') %>

<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Admin Login — Golden Ears Spaniels</title>
  <link rel="preconnect" href="https://fonts.googleapis.com">
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
  <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/css/admin.css">
</head>
<body class="admin-login-body">

  <div class="admin-login-wrap">
    <div class="admin-login-card">

      <div class="admin-login-brand">
        <div class="admin-login-logo">
          <svg viewBox="0 0 60 60" fill="currentColor" xmlns="http://www.w3.org/2000/svg" width="38" height="38">
            <ellipse cx="30" cy="43" rx="16" ry="13"/>
            <ellipse cx="13" cy="29" rx="7" ry="8" transform="rotate(-10 13 29)"/>
            <ellipse cx="47" cy="29" rx="7" ry="8" transform="rotate(10 47 29)"/>
            <ellipse cx="21" cy="18" rx="6" ry="7" transform="rotate(-5 21 18)"/>
            <ellipse cx="39" cy="18" rx="6" ry="7" transform="rotate(5 39 18)"/>
          </svg>
        </div>
        <div>
          <h1 class="admin-login-title">Golden Ears</h1>
          <p class="admin-login-sub">Admin Dashboard</p>
        </div>
      </div>

      <% if (error) { %>
      <div class="admin-alert admin-alert-error">
        <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" width="16" height="16"><circle cx="12" cy="12" r="10"/><line x1="12" y1="8" x2="12" y2="12"/><line x1="12" y1="16" x2="12.01" y2="16"/></svg>
        <%= error %>
      </div>
      <% } %>

      <form action="/admin/login" method="POST" class="admin-form">
        <div class="admin-field">
          <label for="email">Email Address</label>
          <input type="email" id="email" name="email" placeholder="admin@example.com" required autocomplete="email">
        </div>
        <div class="admin-field">
          <label for="password">Password</label>
          <input type="password" id="password" name="password" placeholder="••••••••••" required autocomplete="current-password">
        </div>
        <button type="submit" class="admin-btn-primary admin-btn-full">Sign In</button>
      </form>

      <a href="/" class="admin-back-link">← Back to website</a>
    </div>
  </div>

</body>
</html>

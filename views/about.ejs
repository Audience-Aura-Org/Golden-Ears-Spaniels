<!-- ─── About Hero ───────────────────────────────────────────────── -->
<section class="about-hero">
  <div class="container">
    <div class="breadcrumb">
      <a href="/">Home</a>
      <span class="breadcrumb-sep">/</span>
      <span>About Us</span>
    </div>
    <h1>A Family Breeder, <br>Built on Love & Trust</h1>
    <p class="lead">Since 2019, Golden Ears Spaniels has been raising both American and English Cocker Spaniels the right way — with patience, care, and an unwavering commitment to the health and happiness of every puppy.</p>
  </div>
</section>

<!-- ─── Our Story ────────────────────────────────────────────────── -->
<section class="section" style="background:var(--white);">
  <div class="container">
    <div class="about-intro-grid">
      <div>
        <img
          class="about-intro-img"
          src="https://images.unsplash.com/photo-1548031611-745a4c0e6c93?w=900&auto=format&fit=crop&q=80"
          alt="Cocker Spaniel puppy on grass"
          loading="lazy"
        >
      </div>
      <div>
        <p class="section-label">Our Story</p>
        <h2>Why We Started Golden Ears</h2>
        <p class="lead" style="margin: 20px 0 20px;">
          It started with a single Cocker Spaniel named Bella — and the realization that finding a truly ethical, health-focused breeder was harder than it should be.
        </p>
        <p style="color:var(--text-mid); line-height:1.8; margin-bottom:18px; font-size:.95rem;">
          We founded Golden Ears Spaniels because we believed families deserve better: better transparency, better health testing, better ongoing support. Our puppies are raised inside our home in Georgia — not in commercial kennels — alongside our own children and pets. This in-home environment creates dogs that are naturally socialized, calm, and ready for family life.
        </p>
        <p style="color:var(--text-mid); line-height:1.8; font-size:.95rem;">
          Every litter is carefully planned with champion bloodlines — AKC for our American Cockers and KC for our English Cockers — with comprehensive health testing of all parent dogs. We work with veterinarians we trust, follow responsible breeding standards, and maintain close relationships with every family who adopts from us.
        </p>

        <div class="values-grid" style="margin-top:32px;">
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24"><path d="M2.25 12l8.954-8.955c.44-.439 1.152-.439 1.591 0L21.75 12M4.5 9.75v10.125c0 .621.504 1.125 1.125 1.125H9.75v-4.875c0-.621.504-1.125 1.125-1.125h2.25c.621 0 1.125.504 1.125 1.125V21h4.125c.621 0 1.125-.504 1.125-1.125V9.75M8.25 21h8.25"/></svg>
            </div>
            <div class="value-text">
              <strong>Home Environment</strong>
              <span>Raised indoors with daily family interaction</span>
            </div>
          </div>
          <div class="value-item">
            <div class="value-icon">
              <svg viewBox="0 0 24 24"><path d="M19.5 14.25v-2.625a3.375 3.375 0 00-3.375-3.375h-1.5A1.125 1.125 0 0113.5 7.125v-1.5a3.375 3.375 0 00-3.375-3.375H8.25m0 12.75h7.5m-7.5 3H12M10.5 2.25H5.625c-.621 0-1.125.504-1.125 1.125v17.25c0 .621.504 1.125 1.125 1.125h12.75c.621 0 1.125-.504 1.125-1.125V11.25a9 9 0 00-9-9z"/></svg>

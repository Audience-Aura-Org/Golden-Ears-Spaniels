# Server
PORT=3000

# Admin Email - where contact form submissions are sent
ADMIN_EMAIL=admin@goldenearsspaniels.com

# SMTP Configuration (e.g. Gmail with App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password_here

# Email display name (sender)
FROM_NAME=Golden Ears Spaniels
FROM_EMAIL=your@gmail.com
